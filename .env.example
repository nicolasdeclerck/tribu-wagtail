# Copy to .env and adjust. NEVER commit the real .env.
#   cp .env.example .env

# --- Traefik ------------------------------------------------------------
# Domaine principal (l'apex + www sont routés par les labels du service nginx).
DOMAIN=latribudoya.fr

# --- Django -------------------------------------------------------------
# Generate one with:  python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=change-me-to-a-long-random-string
ALLOWED_HOSTS=latribudoya.fr,www.latribudoya.fr,localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=https://latribudoya.fr,https://www.latribudoya.fr
WAGTAILADMIN_BASE_URL=https://latribudoya.fr
# TLS terminé par Traefik en amont → on active le durcissement HTTPS
# (redirection, cookies sécurisés, HSTS). nginx propage X-Forwarded-Proto.
DJANGO_SECURE_SSL_REDIRECT=true

# --- Database (keep POSTGRES_* and DATABASE_URL consistent) -------------
POSTGRES_DB=tribu
POSTGRES_USER=tribu
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgres://tribu:change-me@db:5432/tribu

# --- First boot helpers (optional) -------------------------------------
# Seed the legacy content automatically on first container start.
SEED_CONTENT=1
# Auto-create an admin (leave blank to create it manually later).
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@latribudoya.fr
DJANGO_SUPERUSER_PASSWORD=change-me-too
